{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["server.ts", "route-handlers.ts", "lib/**/*.ts"]
}
