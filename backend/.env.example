# Copy to backend/.env or use repo-root .env.local (see README).
# SQL Server — required for all /api/* routes that touch the database.
TRACKING_DB_CONNECTION_STRING=Server=...;Database=...;User Id=...;Password=...;Encrypt=true;TrustServerCertificate=true

# Optional
# PORT=3001
# TRACKING_DEFAULT_COMPANY_ID=1
# TRACKING_DEFAULT_FACILITY_NAME=Peak Healthcare

# Census — Power BI execute DAX (used by POST /api/census/power-bi; do not expose secret to the browser).
# POWERBI_EXECUTE_DAX_URL=https://powerbiapi-jrtbvvz2aa-uc.a.run.app/executeDaxQuery
# POWERBI_DATASET_ID=4c41eb0d-2fea-4ed7-8de3-224dad8455c6
# POWERBI_EXECUTE_DAX_SECRET=your-secret-here
